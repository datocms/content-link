{
  "name": "datocms-visual-editing",
  "version": "1.2.3",
  "description": "DatoCMS visual editing overlays without Vercel dependencies.",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE", "LICENSES.md", "CHANGELOG.md", "docs/usage.gif"],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome check .",
    "prepublishOnly": "npm run build && npm run test"
  },
  "keywords": [
    "datocms",
    "visual-editing",
    "stega",
    "content-link",
    "cms",
    "headless-cms",
    "preview"
  ],
  "author": {
    "name": "Marcelo Finamor Vieira",
    "email": "marcelofinamorvieira@gmail.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/jsdom": "^21.1.0",
    "@types/node": "^20.14.10",
    "@types/react": "^19.0.0",
    "@vitest/coverage-v8": "^1.6.0",
    "dotenv": "^16.4.5",
    "jsdom": "^24.0.0",
    "rimraf": "^5.0.5",
    "typescript": "^5.5.4",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@vercel/stega": "^0.1.2"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/marcelofinamorvieira/DatoContentLink.git"
  },
  "bugs": {
    "url": "https://github.com/marcelofinamorvieira/DatoContentLink/issues"
  },
  "homepage": "https://github.com/marcelofinamorvieira/DatoContentLink#readme"
}
