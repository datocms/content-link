{
  "name": "@datocms/content-link",
  "version": "0.2.4",
  "description": "DatoCMS visual editing overlays without Vercel dependencies.",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./stega": {
      "types": "./dist/stega/index.d.ts",
      "import": "./dist/stega/index.js"
    }
  },
  "files": ["src", "dist", "README.md", "LICENSE", "CHANGELOG.md"],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome check .",
    "prepublishOnly": "npm run build && npm run test"
  },
  "keywords": [
    "datocms",
    "visual-editing",
    "stega",
    "content-link",
    "cms",
    "headless-cms",
    "preview"
  ],
  "author": {
    "name": "Stefano Verna",
    "email": "s.verna@datocms.com"
  },
  "contributors": [
    {
      "name": "Marcelo Finamor Vieira",
      "email": "m.finamor@datocms.com"
    }
  ],
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/jsdom": "^21.1.0",
    "@types/node": "^20.14.10",
    "@vitest/coverage-v8": "^1.6.0",
    "dotenv": "^16.4.5",
    "jsdom": "^24.0.0",
    "np": "^10.2.0",
    "rimraf": "^5.0.5",
    "typescript": "^5.5.4",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@vercel/stega": "^0.1.2",
    "compute-scroll-into-view": "^3.1.1",
    "penpal": "^4.1.1"
  }
}
